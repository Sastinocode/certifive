# ──────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS
# ──────────────────────────────────────────────────────────────────────────────

# Cadena de conexión PostgreSQL (Neon, Railway, Supabase, etc.)
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db?sslmode=require

# ──────────────────────────────────────────────────────────────────────────────
# AUTENTICACIÓN Y SESIONES
# ──────────────────────────────────────────────────────────────────────────────

# Secreto para firmar JWT — usa una cadena aleatoria larga (mínimo 32 chars)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME

# Secreto para cifrar las cookies de sesión de Express
SESSION_SECRET=CHANGE_ME

# Clave de cifrado simétrico para datos sensibles en base de datos (AES-256)
# Debe tener exactamente 32 caracteres
ENCRYPTION_KEY=CHANGE_ME

# ──────────────────────────────────────────────────────────────────────────────
# STRIPE — Pagos y suscripciones
# Obtén las keys en: https://dashboard.stripe.com/apikeys
# ──────────────────────────────────────────────────────────────────────────────

# Clave secreta del servidor (NUNCA exponer en el frontend)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secreto de webhook — Stripe > Developers > Webhooks > Signing secret
# En local usa: stripe listen --forward-to localhost:5000/api/subscription/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Price IDs de cada plan — Stripe > Products > (plan) > Pricing
STRIPE_PRICE_BASICO=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PROFESIONAL=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_EMPRESA=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PAY_PER_USE=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Clave pública para el frontend (segura de exponer al cliente)
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Misma clave pública expuesta a Vite para el cliente React
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────────────────────
# SENDGRID — Envío de emails transaccionales
# Obtén la key en: https://app.sendgrid.com/settings/api_keys
# ──────────────────────────────────────────────────────────────────────────────

# API key de SendGrid para enviar emails de verificación, notificaciones, etc.
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────────────────────
# CLOUDINARY — Almacenamiento de fotos y documentos
# Obtén la URL en: https://console.cloudinary.com > Dashboard > API Keys
# ──────────────────────────────────────────────────────────────────────────────

# URL de configuración completa (incluye cloud_name, api_key y api_secret)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ──────────────────────────────────────────────────────────────────────────────
# SENTRY — Monitorización de errores en producción
# Obtén el DSN en: https://sentry.io > Settings > Projects > (tu proyecto) > Client Keys
# ──────────────────────────────────────────────────────────────────────────────

# DSN de Sentry — si está vacío, Sentry queda desactivado (seguro en dev/CI)
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# ──────────────────────────────────────────────────────────────────────────────
# APLICACIÓN
# ──────────────────────────────────────────────────────────────────────────────

# URL pública de la app — usada en links de emails y webhooks
APP_URL=https://tudominio.com

# Puerto en el que escucha el servidor Express (Railway lo inyecta automáticamente)
PORT=5000
