# ─────────────────────────────────────────────────────────────────────────────
# CERTIFIVE — Configuración de entorno
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo a .env y rellena los valores según tu entorno.
# Las variables marcadas como OBLIGATORIAS son necesarias para arrancar la app.
# Las OPCIONALES permiten funcionalidades específicas (emails, pagos, etc.).

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🗄️  BASE DE DATOS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OBLIGATORIO — URL de conexión a PostgreSQL (Neon serverless en producción)
# Formato: postgresql://user:password@host:5432/database?sslmode=require
# Para desarrollo local, solicita acceso a la base de datos de desarrollo al equipo
DATABASE_URL=postgresql://user:password@host/certifive?sslmode=require

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔐  AUTENTICACIÓN Y SEGURIDAD
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OBLIGATORIO — Secret para firmar JWT (tokens de autenticación)
# Genera 64 bytes hexadecimales: openssl rand -hex 64
JWT_SECRET=genera-64-bytes-hex-con-openssl-rand-hex-64

# OBLIGATORIO — Secret para firmar sesiones de Express
# Genera 64 bytes hexadecimales: openssl rand -hex 64
SESSION_SECRET=genera-64-bytes-hex-con-openssl-rand-hex-64

# OBLIGATORIO — Clave para cifrar datos sensibles (WhatsApp API keys, etc.)
# IMPORTANTE: debe tener EXACTAMENTE 32 caracteres (256 bits para AES-256-CBC)
ENCRYPTION_KEY=exactamente-32-caracteres-aqui!!

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📧  SENDGRID (EMAILS TRANSACCIONALES)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPCIONAL — Si no está configurado, los emails se omiten (logs de advertencia)
# Obtén tu API key en: https://app.sendgrid.com/settings/api_keys
# Formato: SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ☁️  CLOUDINARY (ALMACENAMIENTO DE ARCHIVOS)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPCIONAL — Para subir PDFs, imágenes, etc.
# Si no está configurado, las subidas de archivos fallarán
# Obtén tus credenciales en: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 💳  STRIPE (PAGOS Y SUSCRIPCIONES)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPCIONAL — Para pagos con tarjeta y suscripciones SaaS
# Obtén tus claves en: https://dashboard.stripe.com/apikeys
# En desarrollo, usa claves de test (sk_test_...)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Webhook secrets para verificar eventos de Stripe
# Los obtienes al crear webhooks en: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Price IDs de los planes de suscripción (los creas en Stripe Dashboard)
STRIPE_PRICE_BASICO=price_xxxx
STRIPE_PRICE_PRO=price_xxxx
STRIPE_PRICE_PROFESIONAL=price_xxxx
STRIPE_PRICE_EMPRESA=price_xxxx
STRIPE_PRICE_ENTERPRISE=price_xxxx
STRIPE_PRICE_PAY_PER_USE=price_xxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🌐  APLICACIÓN
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Puerto en el que escucha el servidor Express
# Railway asigna automáticamente PORT en producción (no configurar en .env de producción)
PORT=5000

# URL pública de la aplicación (usada en emails, webhooks, etc.)
# En desarrollo: http://localhost:5000
# En producción: https://certifive.es (o tu dominio Railway)
APP_URL=http://localhost:5000

# Nivel de log (debug, info, warn, error)
# En desarrollo: debug | En producción: info
LOG_LEVEL=debug

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📱  WHATSAPP BUSINESS (360DIALOG)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPCIONAL — Cada certificador configura su propia API key desde la UI de CERTIFIVE
# No es necesario configurar esto aquí — solo se usa si quieres probar localmente
# Los certificadores añaden sus claves cifradas desde Ajustes → Integraciones → WhatsApp

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔍  SENTRY (MONITORIZACIÓN DE ERRORES) — OPCIONAL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Si no está configurado, Sentry no se inicializa (no afecta al funcionamiento)
# Obtén tu DSN en: https://sentry.io/settings/projects/
SENTRY_DSN=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🧪  ENTORNO
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Entorno de ejecución (development, production, test)
# Railway configura esto automáticamente en producción
NODE_ENV=development
